# Environment Variables Template
# Copy this to .env and fill in your API keys

# Gemini API Key (Google)
GEMINI_API_KEY=your_gemini_key_here

# Claude API Key (Anthropic)
CLAUDE_API_KEY=your_claude_key_here

# Grok API Key (X.AI) - Optional, for future use
GROK_API_KEY=your_grok_key_here

# ── Trading Engine V7.1 ────────────────────────────────────────────────────────
# Set to "True" for paper trading (simulated), "False" for real exchange trading
PAPER_TRADING=False

# Hard safety switch: set to "True" to enable actual order placement
LIVE_TRADING_ENABLED=True

# Strategy Regime Toggles
ENABLE_MEAN_REVERSION=False
ENABLE_MOMENTUM_BREAKOUT=True

# ── WazirX API ────────────────────────────────────────────────────────────────
# Generate keys at: https://wazirx.com/settings/keys
WAZIRX_API_KEY=your_wazirx_api_key_here
WAZIRX_API_SECRET=your_wazirx_api_secret_here

# ── Binance API ───────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_binance_key_here
BINANCE_API_SECRET=your_binance_secret_here

# Exchange selector — set to "wazirx" or "binance"
ACTIVE_EXCHANGE=binance
